{
  "schema_name": "daic_phq8_symptom_slot_schema",
  "version": "2026-07-21",
  "source": {
    "dataset": "DAIC-WoZ + Extended-DAIC",
    "note": "DAIC is modeled as a PHQ-8 depression-screening environment. The symptom space is exactly the eight PHQ-8 items; suicide/self-harm and broader psychiatric interview context are not evaluator slots for this dataset."
  },
  "task": {
    "diagnosis_labels": ["Depressed", "control"],
    "positive_label": "Depressed",
    "negative_label": "control",
    "label_rule": "Use PHQ8_Binary when provided; otherwise derive Depressed when PHQ8 total >= 10."
  },
  "gate_target_formula": "topic_responsiveness * information_retention * clarity",
  "tree_space": {
    "daic_phq8": [
      "anhedonia",
      "hopelessness_or_crying",
      "sleep",
      "fatigue",
      "appetite_loss",
      "self_worth",
      "attention_decline",
      "psychomotor_change"
    ],
    "unknown": []
  },
  "slots": [
    {
      "slot": "anhedonia",
      "phq8_item": 1,
      "name": "Little interest or pleasure in doing things",
      "evidence_unit_hints": ["interest_loss", "reduced_pleasure", "motivation", "activities"],
      "criticality": "high",
      "question_keywords": ["interest", "pleasure", "enjoy", "motivation", "activities", "hobbies", "fun", "like doing"]
    },
    {
      "slot": "hopelessness_or_crying",
      "phq8_item": 2,
      "name": "Feeling down, depressed, or hopeless",
      "evidence_unit_hints": ["depressed_mood", "sadness", "hopelessness", "crying"],
      "criticality": "high",
      "question_keywords": ["down", "depressed", "hopeless", "sad", "mood", "low mood", "unhappy", "cry", "crying"]
    },
    {
      "slot": "sleep",
      "phq8_item": 3,
      "name": "Trouble falling or staying asleep, or sleeping too much",
      "evidence_unit_hints": ["insomnia", "sleep_maintenance", "early_waking", "hypersomnia"],
      "criticality": "medium",
      "question_keywords": ["sleep", "asleep", "insomnia", "falling asleep", "staying asleep", "wake up", "waking", "oversleep", "sleeping too much", "too much sleep"]
    },
    {
      "slot": "fatigue",
      "phq8_item": 4,
      "name": "Feeling tired or having little energy",
      "evidence_unit_hints": ["fatigue", "low_energy", "exhaustion"],
      "criticality": "medium",
      "question_keywords": ["tired", "energy", "fatigue", "exhausted", "worn out", "drained", "little energy", "low energy"]
    },
    {
      "slot": "appetite_loss",
      "phq8_item": 5,
      "name": "Poor appetite or overeating",
      "evidence_unit_hints": ["poor_appetite", "overeating", "weight_or_food_change"],
      "criticality": "medium",
      "question_keywords": ["appetite", "eating", "eat", "food", "weight", "hungry", "overeating", "overeat", "poor appetite"]
    },
    {
      "slot": "self_worth",
      "phq8_item": 6,
      "name": "Feeling bad about yourself or that you are a failure",
      "evidence_unit_hints": ["worthlessness", "guilt", "failure", "self_esteem"],
      "criticality": "high",
      "question_keywords": ["bad about yourself", "feeling bad", "failure", "guilty", "worth", "worthless", "self esteem", "disappointing", "let people down"]
    },
    {
      "slot": "attention_decline",
      "phq8_item": 7,
      "name": "Trouble concentrating on things",
      "evidence_unit_hints": ["concentration", "attention", "focus", "distractibility"],
      "criticality": "medium",
      "question_keywords": ["concentrate", "concentrating", "concentration", "focus", "focusing", "attention", "reading", "watching tv", "distracted"]
    },
    {
      "slot": "psychomotor_change",
      "phq8_item": 8,
      "name": "Moving or speaking slowly, or being fidgety/restless",
      "evidence_unit_hints": ["psychomotor_slowing", "restlessness", "agitation"],
      "criticality": "medium",
      "question_keywords": ["moving", "speaking", "moving slowly", "speaking slowly", "slow", "slowed down", "restless", "restlessness", "fidgety", "fidgeting", "agitated", "could not sit still"]
    }
  ]
}
