{
  "schema_name": "daic_depression_screening_slot_schema",
  "version": "2026-07-12",
  "source": {
    "note": "English DAIC-WoZ / Extended-DAIC slot schema for profile-grounded active inquiry. Slots align PHQ-8 items plus risk, functioning, and context fields."
  },
  "gate_target_formula": "topic_responsiveness * information_retention * clarity",
  "tree_space": {
    "daic_adult": [
      "anhedonia",
      "hopelessness_or_crying",
      "sleep",
      "fatigue",
      "appetite_loss",
      "self_worth",
      "attention_decline",
      "psychomotor_change",
